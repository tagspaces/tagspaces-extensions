{
  "name": "@tagspaces/url-viewer",
  "version": "1.0.231",
  "description": "A TagSpaces extension allowing you to open url files created from web-browsers or bookmark manangers.",
  "homepage": "https://www.tagspaces.org",
  "main": "main.js",
  "author": {
    "name": "TagSpaces GmbH",
    "email": "info@tagspaces.org",
