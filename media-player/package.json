{
  "name": "@tagspaces/media-player",
  "version": "1.0.253",
  "description": "A TagSpaces extension allowing playing of audio and video files.",
  "homepage": "./",
  "files": [
    "build/"
  ],
  "author": {
    "name": "TagSpaces GmbH",
    "email": "info@tagspaces.org",
    "url": "https://www.tagspaces.org"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite dev --host",
    "build": "tsc && vite build",
    "build-dev": "tsc && vite build --mode development",
    "preview": "vite preview",
    "code-format": "npx prettier --write .",
    "npmpack": "npm run build-dev && npx shx cp -rL build/** ../../release/app/node_modules/@tagspaces/extensions/media-player && npx shx cp package.json ../../release/app/node_modules/@tagspaces/extensions/media-player"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "5.16.8",
    "@mui/material": "5.16.8",
    "@tagspaces/tagspaces-common": "4.5.39",
    "@vidstack/react": "1.15.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "prettier": "2.8.8",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.7.2",
    "vite": "5.4.11"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "tsextension": {
    "name": "Media Player",
    "types": [
      "viewer"
    ],
    "color": "#c5e4f9",
    "fileTypes": [
      {
        "ext": "flac"
      },
      {
        "ext": "mp3"
      },
      {
        "ext": "mp4"
      },
      {
        "ext": "m4a"
      },
      {
        "ext": "oga"
      },
      {
        "ext": "ogg"
      },
      {
        "ext": "ogv"
      },
      {
        "ext": "ogx"
      },
      {
        "ext": "opus"
      },
      {
        "ext": "spx"
      },
      {
        "ext": "wav"
      },
      {
        "ext": "wave"
      },
      {
        "ext": "webm"
      }
    ]
  }
}
